#!/bin/bash

# Pre-commit hook - runs validation before commit
# Usage: Run this script before git commit

set -e

RUN_BUILD=0
if [ "$1" == "--build" ]; then
    RUN_BUILD=1
fi

echo "🔍 Running validation..."

# Detect stack
detect_stack() {
    if [ -f "package.json" ]; then
        echo "node"
    elif [ -f "pyproject.toml" ] || [ -f "requirements.txt" ]; then
        echo "python"
    elif [ -f "Gemfile" ]; then
        echo "ruby"
    elif [ -f "go.mod" ]; then
        echo "go"
    elif [ -f "Cargo.toml" ]; then
        echo "rust"
    else
        echo "unknown"
    fi
}

STACK=$(detect_stack)
echo "📦 Detected stack: $STACK"

run_validation() {
    case "$STACK" in
        node)
            echo "📦 Running Node.js validation..."
            # Detect package manager
            PM="npm"
            if [ -f "pnpm-lock.yaml" ]; then
                PM="pnpm"
            elif [ -f "yarn.lock" ]; then
                PM="yarn"
            elif [ -f "bun.lockb" ]; then
                PM="bun"
            fi
            
            echo "🔧 Using package manager: $PM"
            $PM run lint || { echo "❌ Lint failed"; exit 1; }
            $PM run typecheck || { echo "❌ Typecheck failed"; exit 1; }
            $PM run test || { echo "❌ Tests failed"; exit 1; }
            if [ "$RUN_BUILD" == "1" ]; then
                $PM run build || { echo "❌ Build failed"; exit 1; }
            else
                echo "⏭️  Skipping build step (run with --build to include it)"
            fi
            ;;
        python)
            echo "🐍 Running Python validation..."
            ruff check . || { echo "❌ Lint failed"; exit 1; }
            mypy . || { echo "❌ Type check failed"; exit 1; }
            pytest || { echo "❌ Tests failed"; exit 1; }
            python -m py_compile . || { echo "❌ Syntax check failed"; exit 1; }
            ;;
        ruby)
            echo "💎 Running Ruby validation..."
            rubocop || { echo "❌ Lint failed"; exit 1; }
            bundle exec rspec || { echo "❌ Tests failed"; exit 1; }
            ;;
        go)
            echo "🐹 Running Go validation..."
            golangci-lint run || { echo "❌ Lint failed"; exit 1; }
            go vet ./... || { echo "❌ Vet failed"; exit 1; }
            go test ./... || { echo "❌ Tests failed"; exit 1; }
            go build ./... || { echo "❌ Build failed"; exit 1; }
            ;;
        *)
            echo "⚠️ Unknown stack, skipping validation"
            ;;
    esac
}

run_validation

echo "✅ All validations passed!"
exit 0